{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "cd .. && npm install",
  "buildCommand": "cd .. && npm run build:web && rm -rf server/public && mkdir -p server/public && cp -R client/dist/. server/public/",
  "outputDirectory": "public",
  "framework": null,
  "ignoreCommand": "exit 1",
  "rewrites": [
    {
      "source": "/health",
      "destination": "https://web-production-76c64.up.railway.app/health"
    },
    {
      "source": "/socket.io",
      "destination": "https://web-production-76c64.up.railway.app/socket.io/"
    },
    {
      "source": "/socket.io/",
      "destination": "https://web-production-76c64.up.railway.app/socket.io/"
    },
    {
      "source": "/socket.io/:path*",
      "destination": "https://web-production-76c64.up.railway.app/socket.io/:path*"
    },
    {
      "source": "/((?!socket\\.io(?:/|$)|health$).*)",
      "destination": "/index.html"
    }
  ]
}
